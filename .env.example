DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pinfa?schema=public"

# Google Vision SafeSearch credentials.
# Option 1: path to a Google service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=""
# Option 2: raw service account JSON. Useful in hosted environments.
GOOGLE_APPLICATION_CREDENTIALS_JSON=""
# Optional when not inferable from credentials.
GOOGLE_CLOUD_PROJECT=""

SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_USERNAME="superadmin"
SEED_ADMIN_DISPLAY_NAME="Super Admin"
SEED_ADMIN_PASSWORD_HASH="replace-with-a-real-password-hash"
