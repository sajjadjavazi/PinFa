DATABASE_URL="postgresql://pinfa:pinfa_password@127.0.0.1:5432/pinfa?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google Vision SafeSearch credentials.
# Option 1: path to a Google service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=""
# Option 2: raw service account JSON. Useful in hosted environments.
GOOGLE_APPLICATION_CREDENTIALS_JSON=""
# Option 3: split service account fields. Use \n escapes in the private key.
GOOGLE_VISION_CLIENT_EMAIL=""
GOOGLE_VISION_PRIVATE_KEY=""
# Optional when not inferable from credentials.
GOOGLE_CLOUD_PROJECT=""
GOOGLE_VISION_PROJECT_ID=""

SEED_ADMIN_EMAIL="admin@pinfa.local"
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_DISPLAY_NAME="PinFa Admin"
SEED_ADMIN_PASSWORD="Admin123456"

# Native ads. Leave disabled locally unless testing ad insertion.
YEKTANET_ENABLED="false"
YEKTANET_PUBLISHER_ID=""
YEKTANET_WIDGET_ID=""
YEKTANET_PLACEMENT_ID=""
YEKTANET_SCRIPT_URL=""
